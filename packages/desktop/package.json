{
  "name": "@sahayak/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:electron\"",
    "dev:server": "tsup src/server.ts src/preload.ts src/main.ts --format esm --watch",
    "dev:electron": "wait-on dist/main.js && electron .",
    "build": "tsup src/main.ts src/preload.ts src/server.ts --format esm",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sahayak/server": "workspace:*",
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "ai.sahayak.desktop",
    "productName": "Sahayak",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "../../ui/dist/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.png"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
