{
  "name": "@sahayak/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sahayak": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --platform node --external ssh2 --external child_process --external tty --external debug",
    "dev": "tsup src/index.ts src/cli.ts --format esm --dts --watch --external ssh2 --external child_process",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sahayak/shared": "workspace:*",
    "chokidar": "^4.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cron": "^3.2.0",
    "cron-parser": "^5.0.0",
    "express": "^4.21.0",
    "express-fileupload": "^1.5.2",
    "googleapis": "^173.0.0",
    "http-proxy-middleware": "^3.0.3",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "open": "^10.1.0",
    "playwright": "^1.61.0",
    "ssh2": "^1.17.0",
    "systeminformation": "^5.24.0",
    "uuid": "^11.0.0",
    "ws": "^8.18.0",
    "yargs": "^17.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-fileupload": "^1.5.1",
    "@types/node-cron": "^3.0.11",
    "@types/ssh2": "^1.15.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@types/yargs": "^17.0.33",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "supertest": "^7.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
